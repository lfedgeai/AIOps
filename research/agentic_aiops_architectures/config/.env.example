# Copy to config/.env and add your values. Do not commit config/.env.
#
# Hosted agents: LiteLLM / OpenAI-compatible gateway (required for MaaS agents)
DEEPSEEK_API_BASE=https://your-litellm-gateway.example.com/v1
QWEN3_API_BASE=https://your-litellm-gateway.example.com/v1
LLAMA_SCOUT_API_BASE=https://your-litellm-gateway.example.com/v1
#
# Model API keys (one per agent — get from your LiteLLM admin)
DEEPSEEK_API_KEY=your-deepseek-key
QWEN3_API_KEY=your-qwen3-key
LLAMA_SCOUT_API_KEY=your-llama-scout-key
#
# OpenShift kubeadmin
KUBEADMIN_PASSWORD=your-kubeadmin-password
#
# MLflow (auto-discovered from OpenShift route if unset)
# MLFLOW_TRACKING_URI=https://mlflow-agentic-aiops.apps.your-cluster.example.com
# MLFLOW_TRACKING_INSECURE_TLS=true
