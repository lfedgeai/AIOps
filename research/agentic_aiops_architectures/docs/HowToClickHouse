Databases
SHOW DATABASES
Or:

SELECT name FROM system.databases
Tables in a database
SHOW TABLES FROM otel
Or:

SELECT name FROM system.tables WHERE database = 'otel'
Table schema (columns and types)
DESCRIBE TABLE otel.otel_logs
Or:

SELECT name, type FROM system.columns WHERE database = 'otel' AND table = 'otel_logs'
All tables with row counts
SELECT 
  database,
  name AS table_name,
  total_rows
FROM system.tables 
WHERE database = 'otel'
Via HTTP (curl)
# Port-forward first: oc port-forward -n agentic-aiops svc/clickhouse 8123:8123 &
curl -s 'http://localhost:8123/?query=SHOW+DATABASES'
curl -s 'http://localhost:8123/?query=SHOW+TABLES+FROM+otel'
